<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Top Layer Permeability Calculator</title>
    <style>
      body {
        font-family: Segoe UI, Arial, sans-serif;
        margin: 20px;
        background: #f5f7fb;
        color: #222;
      }
      h1 { margin-bottom: .3em; }
      table {
        border-collapse: collapse;
        margin: 8px 0;
        width: 100%;
        max-width: 320px;
        font-size: .9em;
      }
      th, td { border: 1px solid #bbb; padding: 4px 6px; text-align: center; }
      th { background: #e8eef6; font-weight: 600; }
      input[type=number] { width: 90px; padding: 4px; }
      input[type=text] { width: 220px; padding: 4px; }
      .gas-head { background: #d5e0f2; font-weight: 700; }
      .note { font-size: .85em; color: #555; margin-top: 6px; }
      .wrapper { display: flex; flex-wrap: wrap; gap: 22px; }
      .card {
        background: #fff;
        border: 1px solid #cdd5e1;
        border-radius: 6px;
        padding: 14px;
        box-shadow: 1px 1px 4px rgba(0,0,0,.05);
      }
      .btn {
        background: #1e6be3;
        border: none;
        padding: 8px 16px;
        color: #fff;
        border-radius: 4px;
        cursor: pointer;
        transition: background 0.2s;
      }
      .btn:hover { background: #1653b6; }
      .btn:disabled { background: #2e7d32; cursor: default; }
      .sel-container { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 12px; }
      .sel-card { flex: 1 1 230px; }

      /* schematic */
      .schematic-card { max-width: 340px; }
      #schematicWrapper { display: flex; align-items: center; gap: 14px; }
      #memSVG { border: 1px solid #777; background: #fff; }
      .swatch {
        width: 14px;
        height: 14px;
        display: inline-block;
        margin-right: 6px;
        border: 1px solid #555;
        border-radius: 2px;
      }

      /* validation / errors */
      .error-message {
        color: #d32f2f;
        font-size: .85em;
        margin-top: 6px;
        display: none;
      }
      .error-text { color: #d32f2f; font-weight: bold; font-size: 0.9em; }
    </style>
  </head>

  <body>
    <h1>Top Layer Permeability Calculator</h1>

    <div class="wrapper">
      <div class="card">
        <h3>Layer names &amp; thickness</h3>
        <p>
          <label for="layer2Name"><strong>Top Layer name:&nbsp;</strong></label>
          <input type="text" id="layer2Name" value="Aromatic Polyamide" aria-label="Top layer name">
        </p>
        <table aria-label="Layer thickness inputs">
          <tr>
            <th></th>
            <th>Underlayer (Layer 1)</th>
            <th id="thickName">Top Layer (Layer 2)</th>
          </tr>
          <tr>
            <td class="gas-head">Thickness [µm]</td>
            <td><input type="number" id="t1" value="1" min="0.0001" step="any"
                       aria-label="Underlayer thickness in micrometers"></td>
            <td><input type="number" id="t2" value="0.02" min="0.0001" step="any"
                       aria-label="Top layer thickness in micrometers"></td>
          </tr>
        </table>
        <p class="error-message" id="thicknessError" role="alert">
          Invalid thickness: please enter positive numbers for both layers.
        </p>

        <h4>Underlayer Permeances (GPU)</h4>
        <table id="underlayerTable" aria-label="Underlayer permeance inputs">
          <tr><th>Gas</th><th>GPU<sub>1</sub></th></tr>
        </table>

        <h4>Composite Permeances (GPU)</h4>
        <table id="compositeTable" aria-label="Composite permeance inputs">
          <tr><th>Gas</th><th>GPU<sub>total</sub></th></tr>
        </table>

        <button class="btn" id="calcBtn">Calculate Top Layer</button>
        <p class="note">
          Blank = impermeable (infinite resistance).<br>
          Permeability (Barrer) = GPU × Thickness (µm).<br>
          <em>Note: Composite permeance must be strictly less than Underlayer permeance.</em>
        </p>
      </div>

      <div class="card" style="flex:1">
        <h3>Calculated Top Layer Results</h3>
        <table id="resultTable" style="max-width: 100%;" aria-label="Calculated top layer results"></table>
        <p class="error-message" id="errorMsg" role="alert">
          * Invalid: Composite permeance cannot be greater than or equal to underlayer permeance
          in a series resistance model.
        </p>

        <div class="sel-container">
          <div class="sel-card">
            <h4>Underlayer Selectivity</h4>
            <table id="selL1" aria-label="Underlayer selectivity"></table>
          </div>
          <div class="sel-card">
            <h4 id="selL2Head">Calculated Top Layer</h4>
            <table id="selL2" aria-label="Calculated top layer selectivity"></table>
          </div>
          <div class="sel-card">
            <h4>Composite Selectivity</h4>
            <table id="selTotal" aria-label="Composite selectivity"></table>
          </div>
        </div>
      </div>

      <div class="card schematic-card">
        <h3>Membrane Schematic</h3>
        <div id="schematicWrapper">
          <svg id="memSVG" width="160" height="110" viewBox="0 0 160 110"
               role="img" aria-label="Membrane cross-section schematic"></svg>
          <div id="layerLabels" aria-hidden="true"></div>
        </div>
      </div>
    </div>

    <script>
      /* ---------- Defaults ---------- */
      const defaultGPU1    = {He: 26.7, H2: 48.2, O2: 9, N2: 1.61, CO2: 44.8, CH4: 1.806};
      const defaultGPUcomp = {He: 0.1396, H2: 0.12235, O2: 0.0137, N2: 0.00171, CO2: 0.04332, CH4: 0.00067};

      const gases = ["He", "H2", "O2", "N2", "CO2", "CH4"];
      const selPairs = [
        ["H2","N2"], ["O2","N2"], ["CO2","CH4"], ["CO2","N2"],
        ["H2","CH4"], ["H2","CO2"], ["N2","CH4"], ["He","H2"], ["H2","O2"]
      ];

      /* ---------- Build input tables ---------- */
      const underlayerTbl = document.getElementById("underlayerTable");
      const compositeTbl  = document.getElementById("compositeTable");

      gases.forEach(gas => {
        const row1 = underlayerTbl.insertRow();
        row1.insertCell().textContent = gas;
        const gpu1Input = document.createElement("input");
        gpu1Input.type = "number";
        gpu1Input.id = `GPU1_${gas}`;
        gpu1Input.step = "any";
        gpu1Input.min = "0";
        gpu1Input.value = defaultGPU1[gas];
        gpu1Input.setAttribute("aria-label", `Underlayer permeance for ${gas}`);
        row1.insertCell().appendChild(gpu1Input);

        const row2 = compositeTbl.insertRow();
        row2.insertCell().textContent = gas;
        const gpuCompInput = document.createElement("input");
        gpuCompInput.type = "number";
        gpuCompInput.id = `GPUcomp_${gas}`;
        gpuCompInput.step = "any";
        gpuCompInput.min = "0";
        gpuCompInput.value = defaultGPUcomp[gas];
        gpuCompInput.setAttribute("aria-label", `Composite permeance for ${gas}`);
        row2.insertCell().appendChild(gpuCompInput);
      });

      /* ---------- Helpers ---------- */
      const formatNum = (num) => {
        if (Number.isNaN(num)) return "NaN";
        if (num === 0) return "0";
        const absVal = Math.abs(num);
        if (absVal < 0.001 || absVal > 10000) return num.toExponential(3);
        return parseFloat(num.toPrecision(4)).toString();
      };

      // Returns the top layer GPU given underlayer and composite GPU.
      // Returns 0 if composite is impermeable, -1 if the inputs are physically impossible.
      const extractGPU2 = (gpu1, gpuComp) => {
        if (!gpuComp || gpuComp <= 0) return 0;          // composite impermeable
        if (gpu1 <= 0 && gpuComp > 0) return -1;         // impossible: underlayer impermeable, composite permeable
        if (gpu1 > 0 && gpuComp >= gpu1) return -1;      // impossible: composite >= underlayer
        return 1 / ((1 / gpuComp) - (1 / gpu1));
      };

      /* ---------- Build schematic ---------- */
      const svgEl     = document.getElementById("memSVG");
      const labelsDiv = document.getElementById("layerLabels");
      const colors    = {layer1: "#90c7e8", layer2: "#f5b93b"};
      let rect1, rect2;

      function drawSchematic(thickness1, thickness2, layer1Name, layer2Name) {
        const total     = thickness1 + thickness2 || 1;
        const barHeight = 100;
        const barWidth  = 120;
        const padY      = 5;

        if (!rect1) {
          rect1 = document.createElementNS("http://www.w3.org/2000/svg", "rect");
          rect2 = document.createElementNS("http://www.w3.org/2000/svg", "rect");
          svgEl.appendChild(rect1);
          svgEl.appendChild(rect2);
        }

        // Top layer (layer 2) drawn at top of bar
        rect2.setAttribute("x", 20);
        rect2.setAttribute("y", padY);
        rect2.setAttribute("width", barWidth);
        rect2.setAttribute("height", barHeight * thickness2 / total);
        rect2.setAttribute("fill", colors.layer2);
        rect2.setAttribute("stroke", "#555");

        // Underlayer (layer 1) drawn below top layer
        rect1.setAttribute("x", 20);
        rect1.setAttribute("y", padY + barHeight * thickness2 / total);
        rect1.setAttribute("width", barWidth);
        rect1.setAttribute("height", barHeight * thickness1 / total);
        rect1.setAttribute("fill", colors.layer1);
        rect1.setAttribute("stroke", "#555");

        labelsDiv.innerHTML = "";
        const makeLabel = (color, text) => {
          const p = document.createElement("p");
          p.style.margin = "2px 0";
          p.innerHTML = `<span class="swatch" style="background:${color}"></span>${text}`;
          labelsDiv.appendChild(p);
        };
        makeLabel(colors.layer2, layer2Name);
        makeLabel(colors.layer1, layer1Name);
      }

      /* ---------- Main calculation ---------- */
      function calculate(isClick = false) {
        const layer2Name = (document.getElementById("layer2Name").value || "Top Layer").trim();
        document.getElementById("thickName").textContent = `${layer2Name} (Layer 2)`;
        document.getElementById("selL2Head").textContent = `Calc. ${layer2Name}`;

        const thickness1 = parseFloat(document.getElementById("t1").value);
        const thickness2 = parseFloat(document.getElementById("t2").value);

        const thicknessError = document.getElementById("thicknessError");
        if (Number.isNaN(thickness1) || Number.isNaN(thickness2) || thickness1 <= 0 || thickness2 <= 0) {
          thicknessError.style.display = "block";
          return;
        }
        thicknessError.style.display = "none";

        const gpu1 = {}, gpu2 = {}, gpuComp = {}, permeability2 = {};
        let hasError = false;

        gases.forEach(gas => {
          let underlayerGPU  = parseFloat(document.getElementById(`GPU1_${gas}`).value);
          let compositeGPU   = parseFloat(document.getElementById(`GPUcomp_${gas}`).value);

          if (Number.isNaN(underlayerGPU))  underlayerGPU  = 0;
          if (Number.isNaN(compositeGPU))   compositeGPU   = 0;

          gpu1[gas]    = underlayerGPU;
          gpuComp[gas] = compositeGPU;

          const calculatedGPU2 = extractGPU2(underlayerGPU, compositeGPU);
          gpu2[gas] = calculatedGPU2;

          if (calculatedGPU2 === -1) {
            hasError = true;
            permeability2[gas] = -1;
          } else {
            permeability2[gas] = calculatedGPU2 * thickness2;
          }
        });

        document.getElementById("errorMsg").style.display = hasError ? "block" : "none";

        /* ----- Permeance table ----- */
        const resultTable = document.getElementById("resultTable");
        resultTable.innerHTML = "";
        const headerRow = resultTable.insertRow();
        ["Gas", "GPU₁ (Underlayer)", "GPU_total (Composite)", "Calc. GPU₂", "Calc. P₂ [Barrer]"].forEach(label => {
          const headerCell = document.createElement("th");
          headerCell.textContent = label;
          headerRow.appendChild(headerCell);
        });

        gases.forEach(gas => {
          const row = resultTable.insertRow();
          row.insertCell().textContent = gas;
          row.insertCell().textContent = gpu1[gas]    ? formatNum(gpu1[gas])    : "0";
          row.insertCell().textContent = gpuComp[gas] ? formatNum(gpuComp[gas]) : "0";

          const gpu2Cell = row.insertCell();
          const p2Cell   = row.insertCell();

          if (gpu2[gas] === -1) {
            gpu2Cell.innerHTML = `<span class="error-text">Invalid*</span>`;
            p2Cell.innerHTML   = `<span class="error-text">Invalid*</span>`;
          } else {
            gpu2Cell.textContent = gpu2[gas] > 0 ? formatNum(gpu2[gas])           : "—";
            p2Cell.textContent   = gpu2[gas] > 0 ? formatNum(permeability2[gas])  : "—";
          }
        });

        /* ----- Selectivity tables ----- */
        buildSelectivity("selL1",    gpu1);
        buildSelectivity("selL2",    gpu2, true);
        buildSelectivity("selTotal", gpuComp);

        /* ----- Schematic ----- */
        drawSchematic(thickness1, thickness2, "Underlayer", layer2Name);

        /* ----- Button feedback ----- */
        if (isClick) {
          const btn = document.getElementById("calcBtn");
          btn.textContent = "Calculated!";
          btn.disabled = true;
          setTimeout(() => {
            btn.textContent = "Calculate Top Layer";
            btn.disabled = false;
          }, 800);
        }
      }

      function buildSelectivity(tableId, gpu, hideZero = false) {
        const table = document.getElementById(tableId);
        table.innerHTML = "";
        const headerRow = table.insertRow();
        ["A/B", "α (A/B)"].forEach(label => {
          const headerCell = document.createElement("th");
          headerCell.textContent = label;
          headerRow.appendChild(headerCell);
        });
        selPairs.forEach(([gasA, gasB]) => {
          const row = table.insertRow();
          row.insertCell().textContent = `${gasA}/${gasB}`;

          let value = "—";
          if (gpu[gasA] === -1 || gpu[gasB] === -1) {
            value = "Invalid";
          } else if (gpu[gasB]) {
            value = formatNum(gpu[gasA] / gpu[gasB]);
          } else if (!hideZero) {
            value = "∞";
          }
          row.insertCell().textContent = value;
        });
      }

      /* initial render */
      calculate(false);

      /* Button wired here so onclick attribute isn't needed in HTML */
      document.getElementById("calcBtn").addEventListener("click", () => calculate(true));
    </script>
  </body>
</html>
